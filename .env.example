# Copy to .env and adjust. Used by docker compose variable substitution where noted.

# =============================================================================
# 安全相关（生产环境必须修改）
# =============================================================================

# Fernet key for encrypting Git tokens at rest.
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=scj8iD_Af6Nf9T88DiKphNKhtc_9iZFpsV5i63OPhg0=

SECRET_KEY=change-me-to-a-long-random-string

# =============================================================================
# 网络 / CORS
# =============================================================================

# API (local `uv run` / compose): comma-separated browser origins
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Optional: HTTP(S)_PROXY / NO_PROXY for Git API egress (worker + API use httpx trust_env)

# =============================================================================
# 功能开关 (architecture §3.4)
# =============================================================================

# 开启 AI 智能生成模式。需要同时配置 LLM_BASE_URL。
# FEATURE_LLM=false

# 外部遥测（默认关闭）
# FEATURE_EXTERNAL_TELEMETRY=false

# 允许公开注册（本地账号）
# ALLOW_PUBLIC_OAUTH=true

# =============================================================================
# LLM 配置（仅当 FEATURE_LLM=true 时生效）
# =============================================================================

# OpenAI-compatible API 地址，例如：
#   - https://api.openai.com/v1         (OpenAI)
#   - http://localhost:11434/v1         (Ollama)
#   - http://llm-gateway.company.com    (内网网关)
# LLM_BASE_URL=

# API Key。内网无鉴权时可留空。
# LLM_API_KEY=

# 模型名称
# LLM_MODEL=gpt-4o-mini

# 请求超时（秒）
# LLM_TIMEOUT_SECONDS=120

# =============================================================================
# 对象存储（可选）
# =============================================================================

# S3-compatible 对象存储（MinIO / AWS / 阿里云 OSS）
# 配置后大于 256KB 的 Markdown 结果将自动上传到对象存储，而非存数据库
# S3_ENDPOINT_URL=
# S3_BUCKET=
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=us-east-1

# =============================================================================
# OIDC 单点登录（可选）
# =============================================================================

# OIDC_ISSUER=
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# PUBLIC_APP_URL=http://localhost:8080
# API_PUBLIC_URL=http://localhost:8000
