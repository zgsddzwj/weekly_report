# Copy to .env and adjust. Used by docker compose variable substitution where noted.

# Fernet key for encrypting Git tokens at rest (required in production).
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=scj8iD_Af6Nf9T88DiKphNKhtc_9iZFpsV5i63OPhg0=

SECRET_KEY=change-me-to-a-long-random-string

# API (local `uv run` / compose): comma-separated browser origins
# CORS_ORIGINS=http://localhost:5173,http://localhost:8080

# Optional: HTTP(S)_PROXY / NO_PROXY for Git API egress (worker + API use httpx trust_env)

# Feature flags (architecture §3.4); use true/false strings in compose
# FEATURE_LLM=false
# FEATURE_EXTERNAL_TELEMETRY=false
# ALLOW_PUBLIC_OAUTH=true
